# Copy to .env only inside the approved Hermes work copy. Never place secrets
# in this build kit, source/, browser storage, logs, exports, or screenshots.
APP_HOST=127.0.0.1
APP_PORT=4318
APP_ENV=production
DATABASE_PATH=./data/future-mission-control.sqlite3
SESSION_SECRET=

# Hermes is preferred. Keep AI disabled until an authenticated capability check
# succeeds and the user approves the exact adapter and minimum context.
AI_BACKEND=disabled
HERMES_BASE_URL=
HERMES_PROFILE=AUTO_DETECT_THEN_CONFIRM
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
AI_MODEL=

# Safe first-run defaults. Institutional mode requires a separately supplied,
# validated policy profile; changing this text alone grants no authority.
FUTURE_EDITION=personal
FUTURE_DATA_CEILING=public_synthetic_owner_authored_nonsensitive
FUTURE_MEMORY_MODE=session_only
FUTURE_EXTERNAL_ACTIONS=off
