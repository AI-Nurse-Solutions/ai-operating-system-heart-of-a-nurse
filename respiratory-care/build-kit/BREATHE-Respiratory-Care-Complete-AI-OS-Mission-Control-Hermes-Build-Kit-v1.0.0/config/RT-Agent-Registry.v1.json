  "notice": "The source programs define workflows and systems, not autonomous agents. This registry is a restrictive build-layer addition.",
  "orbit_framework": [
    "Objective & owner",
    "Role, risk & responsibility",
    "Boundaries & budget",
    "Inspect & test",
    "Transfer or terminate"
  ],
  "orbit_lifecycle": [
    "Disabled",
    "Requested",
    "Classified",
    "Scoped",
    "Previewed",
    "Synthetic-Tested",
    "Human-Authorized",
    "Running-One-Bounded-Run",
    "Awaiting-Human-Review",
    "Accepted-or-Rejected",
    "Human-Released-if-applicable",
    "Archived-or-Expired-or-Revoked"
  ],
  "permission_ladder": {
    "PERM-P0 Disabled": "Installed but cannot run.",
    "PERM-P1 Private Nonsensitive or Synthetic Draft": "One exact approved run; no tools or external action.",
    "PERM-P2 Private Approved Read-Only": "One exact approved run against one personally controlled approved source; no write or external action.",
    "PERM-P3 Institution-Approved Read or Sandbox": "One exact approved institutional partition and purpose; read or sandbox only; never a device or clinical write.",
    "PERM-P4 One-Run Staged Nonclinical Write": "Institutional nonclinical only; one exact approved administrative, education or quality-project destination with per-run confirmation and named-human release. Unavailable in personal mode and excluded from every clinical, EHR, order, event, patient-message, paging and device destination.",
    "PERM-P5 Prohibited": "Autonomous clinical action or monitoring, device/alarm access, patient communication, clinical-system write, staffing/evaluation, credential/competency decision, self-expansion, hidden persistence, escalation or recursive delegation."
  },
  "personal_p4_available": false,
  "schema": "NAIO-RT-BREATHE-AGENT-REGISTRY-1",
  "version": "1.0.0"
}
