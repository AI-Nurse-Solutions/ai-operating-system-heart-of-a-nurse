{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nurse-ai-os.local/schemas/soul-profile-input.schema.json",
  "title": "Nurse AI OS Soul Profile Adapter",
  "description": "Derived, deidentified Soul Profile input accepted by DISCOVER Mission Control v2.0.0. This draft adapter carries no raw quiz answers and cannot grant authority or alter safety gates.",
  "$comment": "The application also rejects unsafe object keys, nesting deeper than 12 levels, files over 100 KB, and heuristic matches for direct identifiers or credentials. Those content checks are not expressible in this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "profile_schema_version",
    "quiz_definition_version",
    "scoring_model_version",
    "completed_at",
    "user_confirmed_at",
    "role_constellation",
    "core_values",
    "mission_and_purpose",
    "learner_and_developmental_stage",
    "advanced_studies",
    "working_and_learning_preferences",
    "presentation_preferences",
    "role_synergies",
    "role_tensions",
    "wellness_limits",
    "ai_relationship_preferences",
    "governance_boundaries",
    "dashboard_recommendations",
    "uncertainties",
    "source_provenance",
    "demo"
  ],
  "properties": {
    "schema": {
      "const": "NAIO-SOUL-PROFILE-ADAPTER-1"
    },
    "profile_schema_version": {
      "const": "1.0-draft"
    },
    "quiz_definition_version": {
      "type": "string"
    },
    "scoring_model_version": {
      "type": "string"
    },
    "completed_at": {
      "type": ["string", "null"]
    },
    "user_confirmed_at": {
      "type": ["string", "null"]
    },
    "role_constellation": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "contains": {
        "type": "object",
        "required": ["state"],
        "properties": {
          "state": { "const": "primary" }
        }
      },
      "minContains": 1,
      "maxContains": 1,
      "items": {
        "$ref": "#/$defs/roleConstellationItem"
      }
    },
    "core_values": {
      "$ref": "#/$defs/stringArray30x240"
    },
    "mission_and_purpose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mission", "populations", "guiding_principles"],
      "properties": {
        "mission": {
          "type": "string",
          "maxLength": 600
        },
        "populations": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 120
          }
        },
        "guiding_principles": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 200
          }
        }
      }
    },
    "learner_and_developmental_stage": {
      "$ref": "#/$defs/stringArray30x240"
    },
    "advanced_studies": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "status", "target_date"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160,
            "pattern": ".*\\S.*"
          },
          "status": {
            "enum": ["planned", "active", "paused", "completed"]
          },
          "target_date": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "working_and_learning_preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["communication_style", "decision_style", "learning_preferences"],
      "properties": {
        "communication_style": {
          "type": "string",
          "maxLength": 200
        },
        "decision_style": {
          "type": "string",
          "maxLength": 200
        },
        "learning_preferences": {
          "$ref": "#/$defs/stringArray30x240"
        }
      }
    },
    "presentation_preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["theme_token", "tone"],
      "properties": {
        "theme_token": {
          "enum": ["direction", "evidence", "rigor", "connection", "translation", "renewal"]
        },
        "tone": {
          "type": "string",
          "maxLength": 160
        }
      }
    },
    "role_synergies": {
      "$ref": "#/$defs/stringArray30x240"
    },
    "role_tensions": {
      "$ref": "#/$defs/stringArray30x240"
    },
    "wellness_limits": {
      "$ref": "#/$defs/stringArray30x240"
    },
    "ai_relationship_preferences": {
      "$ref": "#/$defs/stringArray30x240"
    },
    "governance_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "may_support",
        "prepare_only",
        "requires_confirmation",
        "requires_supervision",
        "requires_accountable_human_judgment",
        "never_delegate",
        "memory_allowed",
        "memory_denied",
        "escalation_rules"
      ],
      "properties": {
        "may_support": { "$ref": "#/$defs/stringArray30x240" },
        "prepare_only": { "$ref": "#/$defs/stringArray30x240" },
        "requires_confirmation": { "$ref": "#/$defs/stringArray30x240" },
        "requires_supervision": { "$ref": "#/$defs/stringArray30x240" },
        "requires_accountable_human_judgment": { "$ref": "#/$defs/stringArray30x240" },
        "never_delegate": { "$ref": "#/$defs/stringArray30x240" },
        "memory_allowed": { "$ref": "#/$defs/stringArray30x240" },
        "memory_denied": { "$ref": "#/$defs/stringArray30x240" },
        "escalation_rules": { "$ref": "#/$defs/stringArray30x240" }
      }
    },
    "dashboard_recommendations": {
      "$ref": "#/$defs/stringArray30x240"
    },
    "uncertainties": {
      "$ref": "#/$defs/stringArray30x240"
    },
    "source_provenance": {
      "$ref": "#/$defs/stringArray30x240"
    },
    "demo": {
      "type": "boolean"
    }
  },
  "$defs": {
    "roleConstellationItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role_id", "label", "state", "priority", "authorization_status"],
      "properties": {
        "role_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": ".*\\S.*"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": ".*\\S.*"
        },
        "state": {
          "enum": ["primary", "supporting", "emerging", "contextual"]
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "authorization_status": {
          "enum": ["unverified", "user_asserted", "external_unverified"]
        }
      }
    },
    "stringArray30x240": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "string",
        "maxLength": 240
      }
    }
  }
}
